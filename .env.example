# =============================================================================
# Portfolio Builder SaaS -- Variables d'environnement
# =============================================================================
# Copier ce fichier en .env.local et remplir les valeurs
# JAMAIS committer .env.local dans git
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------

# URL de base de l'application (sans slash final)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Domaine principal (pour le wildcard subdomain)
NEXT_PUBLIC_ROOT_DOMAIN=vizly.fr

# Environnement (development / staging / production)
NODE_ENV=development

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------

# URL du projet Supabase (Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://votre-projet.supabase.co

# Cle publique anonyme (Settings > API > anon key)
# Cette cle est exposee cote client -- les RLS protegent les donnees
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...votre-cle-anon

# Cle de service (Settings > API > service_role key)
# JAMAIS exposer cote client -- uniquement dans les API routes et Server Actions
SUPABASE_SERVICE_ROLE_KEY=eyJ...votre-cle-service

# URL directe de la base PostgreSQL (pour les migrations)
SUPABASE_DB_URL=postgresql://postgres:password@db.votre-projet.supabase.co:5432/postgres

# -----------------------------------------------------------------------------
# Supabase Auth
# -----------------------------------------------------------------------------

# Google OAuth -- Configurer dans Google Cloud Console
# Puis ajouter dans Supabase Dashboard > Auth > Providers > Google
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxx

# URL de redirection apres auth (configuree dans Supabase)
NEXT_PUBLIC_AUTH_REDIRECT_URL=http://localhost:3000/auth/callback

# -----------------------------------------------------------------------------
# Supabase Storage
# -----------------------------------------------------------------------------

# Nom du bucket pour les images de profil et de projets
NEXT_PUBLIC_STORAGE_BUCKET=portfolio-images

# Taille max des images en octets (5 Mo par defaut)
NEXT_PUBLIC_MAX_IMAGE_SIZE=5242880

# -----------------------------------------------------------------------------
# Stripe
# -----------------------------------------------------------------------------

# Cle publique Stripe (Dashboard > Developers > API keys > Publishable key)
# REQUIS en dev et prod : lue par src/lib/stripe/client-browser.ts pour
# initialiser Stripe.js cote client (PaymentElement). Le prefixe NEXT_PUBLIC_
# est obligatoire -- c'est ce qui permet a Next.js d'inliner la valeur dans
# le bundle client. Sans ce prefixe, la variable n'est lue que cote server.
# Commence par pk_test_ en mode test, pk_live_ en prod.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Cle secrete Stripe (Dashboard > Developers > API keys > Secret key)
# JAMAIS exposer cote client
STRIPE_SECRET_KEY=sk_test_xxx

# Secret du webhook Stripe (Dashboard > Developers > Webhooks > Signing secret)
# Genere automatiquement quand on cree le webhook endpoint
STRIPE_WEBHOOK_SECRET=whsec_xxx

# -- Price IDs des abonnements --
# Creer dans Stripe Dashboard > Products

# Plan Starter -- 4.99 EUR/mois
STRIPE_PRICE_STARTER=price_xxx

# Plan Starter annuel -- 50.90 EUR/an (-15%)
STRIPE_PRICE_STARTER_YEARLY=price_xxx

# Plan Pro -- 9.99 EUR/mois
STRIPE_PRICE_PRO=price_xxx

# Plan Pro annuel -- 101.90 EUR/an (-15%)
STRIPE_PRICE_PRO_YEARLY=price_xxx

# -- Price IDs des templates premium (paiement unique) --
# Creer dans Stripe Dashboard > Products (mode: one-time)

# Template Creatif -- 2.99 EUR
STRIPE_PRICE_TEMPLATE_CREATIF=price_xxx

# Template Brutalist -- 2.99 EUR
STRIPE_PRICE_TEMPLATE_BRUTALIST=price_xxx

# Template Elegant -- 2.99 EUR
STRIPE_PRICE_TEMPLATE_ELEGANT=price_xxx

# Template Bento -- 2.99 EUR
STRIPE_PRICE_TEMPLATE_BENTO=price_xxx

# URL de succes apres paiement
STRIPE_SUCCESS_URL=http://localhost:3000/dashboard?payment=success

# URL d'annulation du paiement
STRIPE_CANCEL_URL=http://localhost:3000/dashboard?payment=cancelled

# Active Stripe Tax (TVA automatique) sur les checkouts.
# false par defaut : Vizly est en franchise en base de TVA (art. 293 B du CGI).
# A flipper a true le jour ou Vizly sort de la franchise — le code lit cette
# variable au moment de la creation des subscriptions/payment intents et
# applique automatic_tax: { enabled: true } sans autre changement.
STRIPE_TAX_ENABLED=false

# -----------------------------------------------------------------------------
# Resend (emails transactionnels)
# -----------------------------------------------------------------------------

# Cle API Resend (Dashboard > API Keys)
# En prod : utiliser une cle "sending_access" restreinte au domaine vizly.fr.
# En local : la meme cle ou une cle de test.
RESEND_API_KEY=re_xxx

# Adresse d'envoi pour les emails relationnels (welcome, portfolio publie,
# notifications contact). Les replies sont captures par la redirection OVH
# vers la boite perso.
EMAIL_FROM_HELLO="Vizly <hello@vizly.fr>"

# Adresse d'envoi pour les emails de facturation (paiement, plan, annulation,
# rappel renouvellement). Permet aux utilisateurs de filtrer/separer.
EMAIL_FROM_BILLING="Vizly <billing@vizly.fr>"

# Adresse de Reply-To par defaut. Toutes les reponses arrivent ici via OVH.
EMAIL_REPLY_TO=hello@vizly.fr

# -----------------------------------------------------------------------------
# Vercel (domaines custom -- plan Pro)
# -----------------------------------------------------------------------------

# Token d'API Vercel (Settings > Tokens)
# Utilise pour ajouter des domaines custom via l'API Vercel
VERCEL_API_TOKEN=xxx

# ID du projet Vercel (Settings > General > Project ID)
VERCEL_PROJECT_ID=prj_xxx

# ID de l'equipe Vercel (si applicable)
VERCEL_TEAM_ID=team_xxx

# -----------------------------------------------------------------------------
# Analytics (optionnel -- plan Pro)
# -----------------------------------------------------------------------------

# Activer le tracking des vues de portfolio
ENABLE_ANALYTICS=false
